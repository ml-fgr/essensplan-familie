# ============================================================
#  KONFIGURATION — Essensplan Familie
#  Kopiere diese Datei als ".env.local" und trage deine Werte ein.
#  Jede Installation MUSS eigene Werte für PORT, DB_PATH und
#  SERVICE_NAME haben — nur so bleiben Installationen getrennt.
# ============================================================

# ----------------------------------------------------------
# PFLICHTFELD: Absoluter Pfad zum App-Ordner auf dem Server
# ----------------------------------------------------------
APP_DIR=/var/customers/webs/XXXXX/deine-domain.de

# ----------------------------------------------------------
# PFLICHTFELD: Pfad zur SQLite-Datenbank
# MUSS für jede Installation einzigartig sein!
# Idealerweise AUSSERHALB des App-Ordners, damit git die Datei
# niemals anfassen kann.
# Beispiel: /var/customers/data/essensplan-FGR053/essensplan.db
# ----------------------------------------------------------
DB_PATH=/var/customers/data/essensplan-XXXXX/essensplan.db

# ----------------------------------------------------------
# PFLICHTFELD: Deine Domain (wird in setup.sh für Apache genutzt)
# ----------------------------------------------------------
DOMAIN=deine-domain.de

# ----------------------------------------------------------
# PFLICHTFELD: Session-Secret
# Mindestens 32 Zeichen, zufällig gewählt.
# ----------------------------------------------------------
SESSION_SECRET=hier-mindestens-32-zufaellige-zeichen-eintragen!!

# ----------------------------------------------------------
# Marktguru API (bereits eingetragen, nicht ändern)
# ----------------------------------------------------------
MARKTGURU_CLIENT_KEY=WU/RH+PMGDi+gkZer3WbMelt6zcYHSTytNB7VpTia90=
MARKTGURU_API_KEY=8Kk+pmbf7TgJ9nVj2cXeA7P5zBGv8iuutVVMRfOfvNE=

# ----------------------------------------------------------
# Update-Funktion (optional)
# ----------------------------------------------------------
GITHUB_REPO=ml-fgr/essensplan-familie

# ----------------------------------------------------------
# PORT der App (Standard: 3000)
# Bei mehreren Installationen auf demselben Server verschiedene Ports vergeben,
# z. B. 3000, 3001, 3002 — und in .htaccess denselben Port eintragen.
# ----------------------------------------------------------
PORT=3000

# ----------------------------------------------------------
# Dienst-Manager: entweder SERVICE_NAME (systemd) ODER PM2_APP_NAME
# Jede Installation braucht einen eindeutigen Namen!
# ----------------------------------------------------------
SERVICE_NAME=essensplan
# PM2_APP_NAME=essensplan
